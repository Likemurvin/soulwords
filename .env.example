# ── Server ──
MONGO_URL=mongodb://mongo:27017/soulwords
PORT=3001

# Telegram bot token from @BotFather. Required in production.
BOT_TOKEN=

# Dev-only auth bypass — must be unset/0 in production.
ALLOW_DEV_AUTH=0

# ── Client (Vite, prefix VITE_) ──
VITE_API_URL=
VITE_BOT_USERNAME=
VITE_APP_NAME=

MINI_APP_NAME=
